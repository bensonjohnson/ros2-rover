    <child link="right_wheel"/>
    <origin rpy="0 0 0" xyz="0 -0.072 -0.016"/>
  </joint>
  <!-- Camera Joint (RealSense D435 - front flush with platform front) -->
  <joint name="camera_joint" type="fixed">
    <parent link="platform_link"/>
    <child link="camera_link"/>
    <!-- Camera: 25mm deep, front flush with platform edge at base_length/2 (133.35mm) -->
    <!-- Camera center at: 133.35 - 12.5 = 120.85mm = 0.12085m from base_link center -->
    <!-- Camera mount tower raised 175mm: optical center now 186.5 + 175 = 361.5mm from ground -->
    <!-- Platform at 109.25mm, so offset = 361.5 - 109.25 = 252.25mm -->
    <origin rpy="0 0 0" xyz="0.12085 0 0.25225"/>
  </joint>
