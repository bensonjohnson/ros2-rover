  <!-- IMU Joint (upside down, 25mm from front, centered, on top of base_link) -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin rpy="3.14159 0 0" xyz="0.10835 0 0.029"/>
  </joint>
  <!-- Laser Joint (LD19 LiDAR, mounted flat above RealSense, 38mm BEHIND camera front, 200mm from ground, arrow pointing FORWARD) -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <!-- LiDAR: 38mm diameter, front is 38mm behind camera front -->
    <!-- Camera front at 133.35mm, LiDAR front at 95.35mm, LiDAR center at 76.35mm = 0.07635m -->
    <!-- Measured: Camera top (199mm) + 3mm gap + 35mm/2 = 219.5mm from ground -->
    <!-- Camera mount tower raised 175mm, LiDAR rides with it: 219.5 + 175 = 394.5mm from ground -->
    <!-- base_link at 29mm, so offset = 394.5 - 29 = 365.5mm = 0.3655m -->
    <!-- Arrow points forward, no rotation needed - counterclockwise scan for correct orientation -->
    <origin rpy="0 0 0" xyz="0.07635 0 0.3655"/>
  </joint>
