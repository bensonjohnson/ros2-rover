<?xml version="1.0"?>
<!-- Isaac Sim variant of the tractor URDF.
     Differences from src/tractor_bringup/urdf/tractor.urdf.xacro:
       - Four continuous wheel joints (skid-steer) instead of fixed track joints,
         so the articulation can be driven in sim.
       - Visual track boxes kept as decoration on base_link.
       - base_footprint raised so wheels sit on the ground plane (z=0).
       - Corrected base_link inertia for the real chassis dimensions.
       - Gazebo blocks removed (Isaac ignores them).
     Real robot still uses tractor.urdf.xacro; this file is sim-only. -->
<robot name="tractor">

  <material name="green"><color rgba="0.0 0.6 0.1 1.0"/></material>
  <material name="black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 1.0"/></material>
  <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>

  <!-- Articulation root. Wheel radius is 0.045m, so base_link sits 0.045+0.029=0.074m
       above the ground when wheels touch. -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.2667 0.102 0.058"/></geometry>
      <material name="green"/>
    </visual>
    <!-- Left track (visual only) -->
    <visual>
      <origin rpy="0 0 0" xyz="0 0.072 -0.016"/>
      <geometry><box size="0.2667 0.042 0.09"/></geometry>
      <material name="black"/>
    </visual>
    <!-- Right track (visual only) -->
    <visual>
      <origin rpy="0 0 0" xyz="0 -0.072 -0.016"/>
      <geometry><box size="0.2667 0.042 0.09"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.2667 0.102 0.058"/></geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="5.0"/>
      <!-- Solid box 0.2667 x 0.102 x 0.058, m=5kg -->
      <inertia ixx="0.00574" ixy="0.0" ixz="0.0"
               iyy="0.03104" iyz="0.0"
               izz="0.03397"/>
    </inertial>
  </link>

  <!-- Skid-steer virtual wheels: 4 cylinders, radius 0.045m, length 0.04m.
       Axis along Y. Friction tuned in USD post-import. -->
  <link name="front_left_wheel">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000320" ixy="0.0" ixz="0.0"
               iyy="0.000506" iyz="0.0"
               izz="0.000320"/>
    </inertial>
  </link>
  <link name="front_right_wheel">
    <visual><origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry>
      <material name="black"/></visual>
    <collision><origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry></collision>
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000320" ixy="0.0" ixz="0.0"
               iyy="0.000506" iyz="0.0"
               izz="0.000320"/></inertial>
  </link>
  <link name="rear_left_wheel">
    <visual><origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry>
      <material name="black"/></visual>
    <collision><origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry></collision>
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000320" ixy="0.0" ixz="0.0"
               iyy="0.000506" iyz="0.0"
               izz="0.000320"/></inertial>
  </link>
  <link name="rear_right_wheel">
    <visual><origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry>
      <material name="black"/></visual>
    <collision><origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.04"/></geometry></collision>
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000320" ixy="0.0" ixz="0.0"
               iyy="0.000506" iyz="0.0"
               izz="0.000320"/></inertial>
  </link>

  <!-- Platform deck -->
  <link name="platform_link">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.2667 0.102 0.0025"/></geometry>
      <material name="blue"/></visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.2667 0.102 0.0025"/></geometry></collision>
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000435" ixy="0.0" ixz="0.0"
               iyy="0.002963" iyz="0.0"
               izz="0.003396"/></inertial>
  </link>

  <!-- RealSense D435i body -->
  <link name="camera_link">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.025 0.09 0.025"/></geometry>
      <material name="black"/></visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.025 0.09 0.025"/></geometry></collision>
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000731" ixy="0.0" ixz="0.0"
               iyy="0.0000156" iyz="0.0"
               izz="0.0000731"/></inertial>
  </link>

  <!-- IMU -->
  <link name="imu_link">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><box size="0.01 0.01 0.003"/></geometry>
      <material name="red"/></visual>
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="0.0000001" ixy="0.0" ixz="0.0"
               iyy="0.0000001" iyz="0.0"
               izz="0.0000001"/></inertial>
  </link>

  <!-- LD19 LiDAR -->
  <link name="laser_link">
    <visual><origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.035" radius="0.019"/></geometry>
      <material name="black"/></visual>
    <visual><origin rpy="0 0 0" xyz="0 0 0.0175"/>
      <geometry><cylinder length="0.008" radius="0.015"/></geometry>
      <material name="white"/></visual>
    <collision><origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.035" radius="0.019"/></geometry></collision>
    <inertial><origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.015"/>
      <inertia ixx="0.0000020" ixy="0.0" ixz="0.0"
               iyy="0.0000020" iyz="0.0"
               izz="0.0000027"/></inertial>
  </link>

  <!-- ======================== Joints ======================== -->

  <!-- base_footprint to base_link: 0.045 (wheel radius) + 0.029 (base half-height) = 0.074 -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.074"/>
  </joint>

  <!-- Wheels: ±0.09m fore/aft, ±0.072m lateral, -0.029m vertical (so wheel center
       is 0.045m above ground when base_link is at z=0.074). -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="front_left_wheel"/>
    <origin rpy="0 0 0" xyz="0.09 0.072 -0.029"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="front_right_wheel"/>
    <origin rpy="0 0 0" xyz="0.09 -0.072 -0.029"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="rear_left_wheel"/>
    <origin rpy="0 0 0" xyz="-0.09 0.072 -0.029"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="rear_right_wheel"/>
    <origin rpy="0 0 0" xyz="-0.09 -0.072 -0.029"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="platform_joint" type="fixed">
    <parent link="base_link"/><child link="platform_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.08025"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="platform_link"/><child link="camera_link"/>
    <origin rpy="0 0 0" xyz="0.12085 0 0.25225"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/><child link="imu_link"/>
    <origin rpy="3.14159 0 0" xyz="0.10835 0 0.029"/>
  </joint>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/><child link="laser_link"/>
    <origin rpy="0 0 0" xyz="0.07635 0 0.3655"/>
  </joint>

  <!-- Drive transmissions: velocity-controlled wheels.
       Isaac's URDF importer reads these to create joint drives. -->
  <transmission name="front_left_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="front_left_wheel_joint">
      <hardwareInterface>VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="front_left_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="front_right_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="front_right_wheel_joint">
      <hardwareInterface>VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="front_right_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="rear_left_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="rear_left_wheel_joint">
      <hardwareInterface>VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="rear_left_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>
  <transmission name="rear_right_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="rear_right_wheel_joint">
      <hardwareInterface>VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="rear_right_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
  </transmission>

</robot>
